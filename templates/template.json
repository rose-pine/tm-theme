  "tokenColors": [
    {
      "scope": [
        "comment"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "$muted"
      }
    },
    {
      "scope": [
        "constant"
      ],
      "settings": {
        "foreground": "$pine"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "$rose"
      }
    },
    {
      "scope": [
        "entity.name"
      ],
      "settings": {
        "foreground": "$rose"
      }
    },
    {
      "scope": [
        "entity.name.section",
        "entity.name.tag",
        "entity.name.namespace",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "$foam"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.inherited-class"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "$iris"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "$love"
      }
    },
    {
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "$subtle"
      }
    },
    {
      "scope": [
        "keyword",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "$pine"
      }
    },
    {
      "scope": [
        "markup.inserted.diff"
      ],
      "settings": {
        "foreground": "$foam"
      }
    },
    {
      "scope": [
        "markup.deleted.diff"
      ],
      "settings": {
        "foreground": "$love"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold.markdown",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic.markdown",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "meta.diff.range"
      ],
      "settings": {
        "foreground": "$iris"
      }
    },
    {
      "scope": [
        "meta.tag",
        "meta.brace"
      ],
      "settings": {
        "foreground": "$text"
      }
    },
    {
      "scope": [
        "meta.import",
        "meta.export"
      ],
      "settings": {
        "foreground": "$pine"
      }
    },
    {
      "scope": "meta.directive.vue",
      "settings": {
        "fontStyle": "italic",
        "foreground": "$iris"
      }
    },
    {
      "scope": "meta.property-name.css",
      "settings": {
